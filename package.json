{
  "name": "@glitchproof/typenator",
  "version": "0.1.0",
  "description": "TypeScript utility types library",
  "type": "module",
  "author": {
    "name": "GlitchProof",
    "url": "https://github.com/RashadNazarzade"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/RashadNazarzade/typenator.git"
  },
  "bugs": {
    "url": "https://github.com/RashadNazarzade/typenator/issues"
  },
  "workspaces": [
    ".",
    "packages/*"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@glitchproof/typenator/core": "workspace:*"
  },
  "scripts": {
    "prepare": "lefthook install",
    "build": "bun run --filter './packages/*' build && bun run build:root",
    "build:root": "tsdown",
    "build:core": "bun run --filter @glitchproof/typenator/core build",
    "test": "bun run --filter './packages/*' test",
    "test:watch": "vitest --typecheck",
    "format": "prettier --write 'packages/*/src/**/*.{ts,json,md}'",
    "typecheck": "bun run --filter './packages/*' typecheck",
    "clean": "bun run --filter './packages/*' clean && rm -rf dist && rm -rf node_modules",
    "dev": "bun run --filter './packages/*' dev",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "bun run build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.1",
    "lefthook": "^2.1.1",
    "prettier": "^3.2.4",
    "tsdown": "^0.2.16",
    "typescript": "^5.3.3",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.0.0"
  },
  "packageManager": "bun@1.3.0"
}
