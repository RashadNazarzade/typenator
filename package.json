{
  "name": "@glitchproof/typenator",
  "version": "0.1.0",
  "description": "TypeScript utility types library",
  "type": "module",
  "author": {
    "name": "GlitchProof",
    "url": "https://github.com/RashadNazarzade"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/RashadNazarzade/typenator.git"
  },
  "bugs": {
    "url": "https://github.com/RashadNazarzade/typenator/issues"
  },
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./core": {
      "import": "./dist/core/index.js",
      "types": "./dist/core/index.d.ts"
    },
    "./core/primitives": {
      "import": "./dist/core/primitives/index.js",
      "types": "./dist/core/primitives/index.d.ts"
    },
    "./core/conditionals": {
      "import": "./dist/core/conditionals/index.js",
      "types": "./dist/core/conditionals/index.d.ts"
    },
    "./core/guards": {
      "import": "./dist/core/guards/index.js",
      "types": "./dist/core/guards/index.d.ts"
    },
    "./core/extractors": {
      "import": "./dist/core/extractors/index.js",
      "types": "./dist/core/extractors/index.d.ts"
    },
    "./core/mappers": {
      "import": "./dist/core/mappers/index.js",
      "types": "./dist/core/mappers/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "dependencies": {},
  "scripts": {
    "prepare": "lefthook install",
    "build": "tsdown",
    "test": "vitest run",
    "format": "prettier --write 'packages/**/*.{ts,md.json,tsx}'",
    "clean": "rm -rf dist",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "bun run build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.1",
    "lefthook": "^2.1.1",
    "prettier": "^3.2.4",
    "tsdown": "^0.21.0-beta.2",
    "typescript": "^5.3.3",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.0.0"
  },
  "packageManager": "bun@1.3.0"
}
